# このファイルをコピーして .env にし、値を埋める。.env は Git に含めない。
#
# 秘密ファイルの保存先（リポジトリ外のディレクトリを推奨）
# Windows 例:
# BCG_LIST_UP_SECRETS_DIR=C:\Users\YourName\AppData\Local\BCG-list-up\secrets
#
# 未設定の場合は ユーザーホーム下の .bcg-list-up-secrets が使われる。

BCG_LIST_UP_SECRETS_DIR=

# 各種 API キー（使用するサービスだけ設定）
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
